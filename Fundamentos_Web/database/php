<?php

// DEFINIR CREDENCIAIS:
$servidor = "127.0.0.1";
$usuario = "root";
$senha = "";
$banco = "empresa";

$conexao = new mysqli($servidor, $usuario, $senha, $banco);

if ($conexao->connect_error) {
    die("Erro na conexão: " . $conexao->connect_error . ".\n");
} else {
    echo "Conectou ao banco de dados com sucesso!\n";
}

function buscarFuncaoFuncionario($nomeFuncionario, $conexao) {
    if (empty($nomeFuncionario)) {
        echo "Erro: nome do funcionário não pode estar vazio.\n";
        return;
    }

    $sqlFuncionario = "SELECT id_funcao FROM funcionarios WHERE nome = ?";

    $stmtFuncionario = $conexao->prepare($sqlFuncionario);

    if (!$stmtFuncionario) {
        echo "Erro ao preparar consulta do funcionário: " . $conexao->error . "\n";
        return;
    }

    $stmtFuncionario->bind_param("s", $nomeFuncionario);

    if (!$stmtFuncionario->execute()) {
        echo "Erro ao executar consulta do funcionário: " . $stmtFuncionario->error . "\n";
        $stmtFuncionario->close();
        return;
    }

    $resultadoFuncionario = $stmtFuncionario->get_result();

    if ($resultadoFuncionario->num_rows == 0) {
        echo "Funcionário " . $nomeFuncionario . " não encontrado.\n";
        $stmtFuncionario->close();
        return;
    }

    $funcionario = $resultadoFuncionario->fetch_assoc();
    $idFuncao = $funcionario["id_funcao"];

    $stmtFuncionario->close();

    $sqlFuncao = "SELECT descricao FROM funcoes WHERE id = ?";

    $stmtFuncao = $conexao->prepare($sqlFuncao);

    if (!$stmtFuncao) {
        echo "Erro ao preparar consulta da função: " . $conexao->error . "\n";
        return;
    }

    $stmtFuncao->bind_param("i", $idFuncao);

    if (!$stmtFuncao->execute()) {
        echo "Erro ao executar consulta da função: " . $stmtFuncao->error . "\n";
        $stmtFuncao->close();
        return;
    }

    $resultadoFuncao = $stmtFuncao->get_result();

    if ($resultadoFuncao->num_rows == 0) {
        echo "Função com ID " . $idFuncao . " não encontrada.\n";
        $stmtFuncao->close();
        return;
    }

    $funcao = $resultadoFuncao->fetch_assoc();

    echo "Funcionario " . $nomeFuncionario . " tem a funcao " . $funcao["descricao"] . "\n";

    $stmtFuncao->close();
}

buscarFuncaoFuncionario("Joao", $conexao);

$conexao->close();

?>