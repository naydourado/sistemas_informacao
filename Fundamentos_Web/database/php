<?php

// DEFINIR CREDENCIAIS:
$servidor = "127.0.0.1";
$usuario = "root";
$senha = "";
$banco = "empresa";

$conexao = new mysqli($servidor, $usuario, $senha, $banco);

if ($conexao->connect_error) {
    die("Erro na conexão: " . $conexao->connect_error . ".\n");
} else {
    echo "Conectou ao banco de dados com sucesso!\n";
}

function buscarFuncaoFuncionario($nomeFuncionario) {
    global $conexao;

    $sql = "
        SELECT f.nome, fu.descricao
        FROM funcionarios f
        INNER JOIN funcoes fu
        ON f.id_funcao = fu.id
        WHERE f.nome = ?
    ";

    $consulta = $conexao->prepare($sql);

    if (!$consulta) {
        echo "Erro ao preparar consulta: " . $conexao->error . "\n";
        return;
    }

    $consulta->bind_param("s", $nomeFuncionario);

    if (!$consulta->execute()) {
        echo "Erro ao executar consulta: " . $consulta->error . "\n";
        return;
    }

    $resultado = $consulta->get_result();

    if ($resultado->num_rows > 0) {
        $linha = $resultado->fetch_assoc();

        echo "Funcionario " . $linha["nome"] . " tem a funcao " . $linha["descricao"] . "\n";
    } else {
        echo "Funcionario " . $nomeFuncionario . " não encontrado.\n";
    }

    $consulta->close();
}

buscarFuncaoFuncionario("Joao");

$conexao->close();

?>